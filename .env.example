# =========================================================
# MapaSeller — exemplo de variáveis de ambiente
# Use este arquivo como referência. NÃO comite o .env real.
# =========================================================

# -----------------------------------------------------------------
# App / runtime
# -----------------------------------------------------------------
APP_ENV=development
PUBLIC_APP_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:8000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------
# Banco de dados
# - Dev local: SQLite (fallback automático se DATABASE_URL não for setado)
# - Equipe/produção: Supabase Postgres
#   ex.: postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
# -----------------------------------------------------------------
DATABASE_URL=sqlite:///./radar_marketplace.db

# -----------------------------------------------------------------
# Supabase (somente backend; service role NUNCA no frontend)
# -----------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# -----------------------------------------------------------------
# Mercado Livre — OAuth oficial (sem scraping)
# Configure o app em developers.mercadolivre.com.br
# -----------------------------------------------------------------
MERCADOLIVRE_ENABLED=false
MERCADOLIVRE_SITE_ID=MLB
MERCADOLIVRE_CLIENT_ID=
MERCADOLIVRE_CLIENT_SECRET=
MERCADOLIVRE_REDIRECT_URI=http://localhost:8000/mercadolivre/auth/callback
MERCADOLIVRE_MAX_RESULTS=50
MERCADOLIVRE_TIMEOUT_SECONDS=10
MERCADOLIVRE_CACHE_TTL_HOURS=24
MERCADOLIVRE_FALLBACK_TO_MOCK=true

# -----------------------------------------------------------------
# Marketplace timeout genérico
# -----------------------------------------------------------------
MARKETPLACE_TIMEOUT_SECONDS=10
